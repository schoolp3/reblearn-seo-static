# === Vercel AI Gateway (required for the assistant) ===
# Dashboard: Project → AI Gateway, or https://vercel.com/docs/ai-gateway
# Add the same variables under Vercel → Project → Settings → Environment Variables
# (Production + Preview as needed). Redeploy after changing secrets.

AI_GATEWAY_API_KEY=

# Gateway model id. Primary default in code is Claude Haiku; override here or in Vercel.
# Examples:
#   anthropic/claude-haiku-4.5
#   anthropic/claude-sonnet-4.5
#   anthropic/claude-opus-4.5
REBLEARN_AI_MODEL=anthropic/claude-haiku-4.5

# === Public site URL ===
# Used for metadata, canonical URLs, and assistant “next step” links.
NEXT_PUBLIC_SITE_URL=https://www.reblearn.com

# Optional: /psychology-today redirects when set
# NEXT_PUBLIC_PSYCHOLOGY_TODAY_URL=

# === Vercel (usually automatic) ===
# VERCEL_URL — preview host when NEXT_PUBLIC_SITE_URL is unset
